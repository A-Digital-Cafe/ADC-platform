{
	"uiModule": {
		"enableSEO": true,
		"name": "community-home",
		"uiNamespace": "adc-platform",
		"uiName": "Comunidad",
		"framework": "react",
		"outputDir": "dist-ui",
		"isHost": true,
		"isRemote": false,
		"serviceWorker": true,
		"uiDependencies": ["adc-ui-library"],
		"devPort": 3010,
		"sharedLibs": ["react", "tailwind"],
		"i18n": true,
		"security": {
			"headers": {
				"Content-Security-Policy-Extend": "img-src https:; frame-src https://www.youtube.com; child-src https://www.youtube.com"
			}
		},
		"hosting": [
			{
				"domains": ["adigitalcafe.com"],
				"subdomains": ["community"]
			}
		],
		"federationExposes": {
			"./platformLinkResolver": "./src/utils/platform-links-resolver.ts"
		}
	},
	"services": [
		{
			"name": "content-service",
			"version": "latest",
			"language": "typescript"
		},
		{
			"name": "SEOService",
			"version": "latest",
			"optional": true
		}
	]
}
