{
	"uiModule": {
		"enableSEO": true,
		"name": "adc-home",
		"uiNamespace": "adc-platform",
		"uiName": "Inicio",
		"framework": "react",
		"outputDir": "dist-ui",
		"isHost": true,
		"isRemote": false,
		"serviceWorker": true,
		"uiDependencies": ["adc-ui-library"],
		"devPort": 3024,
		"sharedLibs": ["react", "tailwind"],
		"i18n": true,
		"security": {
			"headers": {
				"Content-Security-Policy-Extend": "img-src https:; frame-src https://www.youtube.com; child-src https://www.youtube.com"
			}
		},
		"hosting": [
			{
				"domains": ["adigitalcafe.com"]
			},
			{
				"domains": ["adigitalcafe.com"],
				"subdomains": ["*"]
			}
		]
	},
	"services": [
		{
			"name": "SEOService",
			"version": "latest",
			"optional": true
		}
	]
}
