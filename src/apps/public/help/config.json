{
	"uiModule": {
		"enableSEO": true,
		"name": "help",
		"uiNamespace": "adc-platform",
		"framework": "react",
		"outputDir": "dist-ui",
		"isHost": true,
		"isRemote": false,
		"serviceWorker": true,
		"uiDependencies": ["adc-ui-library"],
		"devPort": 3022,
		"sharedLibs": ["react", "tailwind"],
		"i18n": true,
		"security": {
			"headers": {
				"Content-Security-Policy-Extend": "img-src https:"
			}
		},
		"hosting": [
			{
				"domains": ["adigitalcafe.com"],
				"subdomains": ["help"]
			}
		]
	},
	"services": [
		{
			"name": "SEOService",
			"version": "latest"
		}
	]
}
