{
	"uiModule": {
		"enableSEO": true,
		"name": "adc-identity",
		"uiNamespace": "adc-platform",
		"framework": "react",
		"outputDir": "dist-ui",
		"isHost": true,
		"isRemote": false,
		"serviceWorker": true,
		"uiDependencies": ["adc-ui-library"],
		"devPort": 3014,
		"sharedLibs": ["react", "tailwind"],
		"i18n": true,
		"security": {
			"headers": {
				"Content-Security-Policy-Extend": "img-src https:"
			}
		},
		"hosting": [
			{
				"domains": ["adigitalcafe.com"],
				"subdomains": ["identity"]
			}
		],
		"federationExposes": {
			"./App": "./src/App.tsx"
		}
	},
	"services": [
		{
			"name": "SEOService",
			"version": "latest",
			"optional": true
		}
	]
}
