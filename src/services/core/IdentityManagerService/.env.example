# IdentityManagerService — variables interpoladas en config.json

# S3 interno para avatares (provider object/internal-s3-provider)
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
AVATARS_S3_BUCKET=adc-avatars

# Guild de Discord para el mapeo de roles (private.discordGuildId)
DISCORD_GUILD_ID=

# Región global default (private.defaultRegionObjectUri)
MONGODB_URI=mongodb://localhost:27017/adc-platform

# Passwords de los usuarios de dev (private.devUserPasswords; solo NODE_ENV=development).
# Si no se definen, aplican los defaults declarados en config.json.
DEV_USER_PASSWORD_DEVADMIN=
DEV_USER_PASSWORD_DEVORGADMIN=
DEV_USER_PASSWORD_DEVDATAMANAGER=
DEV_USER_PASSWORD_DEVSECMANAGER=
