{
	"kernelMode": 60,
	"name": "IdentityManagerService",
	"privileges": ["identity:internal", "moderation:internal"],
	"version": "1.0.0",
	"failOnError": true,
	"providers": [
		{
			"name": "object/mongo",
			"version": "latest",
			"language": "typescript",
			"custom": {
				"uri": "mongodb://admin:password@localhost:27017/adc-core?authSource=admin",
				"maxRetries": 5,
				"retryDelay": 5000
			}
		},
		{
			"name": "object/internal-s3-provider",
			"version": "latest",
			"language": "typescript",
			"custom": {
				"endpoint": "${S3_ENDPOINT}",
				"region": "${S3_REGION}",
				"accessKey": "${S3_ACCESS_KEY}",
				"secretKey": "${S3_SECRET_KEY}",
				"bucket": "${AVATARS_S3_BUCKET:-adc-avatars}",
				"presignTtl": 600
			}
		}
	],
	"utilities": [{ "name": "attachments/attachments-utility", "version": "latest" }],
	"services": [
		{
			"name": "SessionManagerService",
			"version": "latest",
			"optional": true
		},
		{
			"name": "EndpointManagerService",
			"version": "latest",
			"optional": true
		},
		{
			"name": "OperationsService",
			"version": "latest"
		}
	],
	"private": {
		"discordGuildId": "${DISCORD_GUILD_ID}",
		"defaultRegionObjectUri": "${MONGODB_URI:-mongodb://localhost:27017/adc-platform}",
		"discordRoleMap": {
			"1402525398788739145": "Discord VIP",
			"858592931594502166": "Discord Nitro Booster"
		}
	}
}
