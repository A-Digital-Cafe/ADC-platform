{
	"name": "EndpointManagerService",
	"version": "1.0.0",
	"kernelMode": 50,
	"failOnError": true,
	"private": {
		"csrf": {
			"enabled": "${CSRF_ENABLED}",
			"secret": "${CSRF_SECRET}",
			"ttlSeconds": "${CSRF_TTL_SECONDS}",
			"secureCookie": "${CSRF_SECURE_COOKIE}"
		},
		"apiDocs": {
			"enabled": "${API_DOCS_ENABLED}"
		},
		"rateLimit": {
			"enabled": "${ENDPOINT_RATE_LIMIT_ENABLED:-true}",
			"readMax": "${ENDPOINT_RATE_LIMIT_READ_MAX:-600}",
			"mutationMax": "${ENDPOINT_RATE_LIMIT_MUTATION_MAX:-120}",
			"windowMs": "${ENDPOINT_RATE_LIMIT_WINDOW_MS:-60000}"
		}
	},
	"providers": [
		{
			"name": "fastify-server",
			"version": "latest",
			"language": "typescript"
		},
		{
			"name": "queue/rabbitmq",
			"version": "latest",
			"language": "typescript",
			"custom": {
				"url": "amqp://admin:password@localhost:5672",
				"defaultPrefetch": 10,
				"defaultConcurrency": 5,
				"maxRetries": 4,
				"retryDelaysMs": [1000, 5000, 25000, 125000]
			}
		},
		{
			"name": "queue/redis",
			"version": "latest",
			"language": "typescript",
			"custom": {
				"host": "${REDIS_HOST:-localhost}",
				"port": "${REDIS_PORT:-6380}",
				"password": "${REDIS_PASSWORD}",
				"db": 0,
				"keyPrefix": "adc:jobs:"
			}
		}
	],
	"services": [
		{
			"name": "SessionManagerService",
			"version": "latest",
			"optional": true
		},
		{
			"name": "OperationsService",
			"version": "latest"
		}
	]
}
