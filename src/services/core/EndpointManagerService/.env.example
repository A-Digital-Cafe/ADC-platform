# EndpointManagerService
API_DOCS_ENABLED=true
CSRF_ENABLED=true
CSRF_SECRET=replace-with-openssl-rand-base64-48
CSRF_TTL_SECONDS=7200

CSRF_SECURE_COOKIE=

# Producción: CSRF_SECRET es obligatorio y debe ser estable entre reinicios/instancias.
# CSRF_SECURE_COOKIE=true

# Rate limiting (Redis). El kill-switch global no aplica a endpoints públicos sin auth.
ENDPOINT_RATE_LIMIT_ENABLED=true
ENDPOINT_RATE_LIMIT_READ_MAX=600
ENDPOINT_RATE_LIMIT_MUTATION_MAX=120
ENDPOINT_RATE_LIMIT_WINDOW_MS=60000
