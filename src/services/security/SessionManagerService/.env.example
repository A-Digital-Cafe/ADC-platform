# SessionManagerService — variables interpoladas en config.json

# JWT (provider security/jwt); mín. 32 caracteres, solo si no se usa rotación de claves
JWT_SECRET=

# OAuth providers
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis (estado distribuido; opcional, con fallback en memoria)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# Overrides de dominio (vacío = default por entorno: localhost en dev, adigitalcafe.com en prod)
SESSION_COOKIE_DOMAIN=
SESSION_DEFAULT_REDIRECT_URL=
