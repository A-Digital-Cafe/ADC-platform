{
	"name": "adc-platform",
	"private": true,
	"version": "0.1.0",
	"description": "Un kernel de módulos dinámicos.",
	"type": "module",
	"workspaces": [
		"src/apps/*/*",
		"src/providers/*/*",
		"src/utilities/*/*",
		"src/services/*/*",
		"presets/*/apps/**",
		"presets/*/providers/**",
		"presets/*/utilities/**",
		"presets/*/services/**"
	],
	"scripts": {
		"postinstall": "node scripts/sync-presets.mjs",
		"start": "cross-env NODE_ENV=production bun src/index.ts",
		"dev": "cross-env NODE_ENV=development ENABLE_TESTS=true bun src/index.ts",
		"start:prodtests": "cross-env NODE_ENV=production ENABLE_TESTS=true PROD_PORT=3000 bun src/index.ts",
		"lint": "eslint src --ext .ts --max-warnings 0",
		"lint:fix": "eslint src --ext .ts --fix",
		"typecheck": "bash scripts/recursive-typecheck.sh && knip --exports",
		"extra-checks": "bash scripts/find-large-files.sh && knip --dependencies",
		"cleanup": "bash scripts/cleanup-processes.sh",
		"proto:gen": "cd src/common/ADC/proto && npx buf generate",
		"create:app": "node scripts/create-app.mjs",
		"create:service": "node scripts/create-service.mjs",
		"create:utility": "node scripts/create-utility.mjs",
		"create:provider": "node scripts/create-provider.mjs",
		"build:ui": "cd src/apps/public/00-adc-ui-library && npx stencil build && cd ../../../.. && node scripts/generate-ui-library-runtime.mjs && node scripts/generate-react-jsx.mjs src/apps/public/00-adc-ui-library"
	},
	"keywords": [
		"kernel",
		"modular",
		"plugin",
		"framework",
		"typescript"
	],
	"author": "abbytec",
	"license": "ISC License",
	"dependencies": {
		"@astrojs/react": "^5.0.5",
		"@bufbuild/buf": "^1.69.0",
		"@bufbuild/protobuf": "^2.12.0",
		"@bufbuild/protoc-gen-es": "^2.12.0",
		"@connectrpc/connect-web": "^2.1.1",
		"@sinclair/typebox": "^0.34.0",
		"@vitejs/plugin-react": "^5.2.0",
		"astro": "^6.4.6",
		"chokidar": "^5.0.0",
		"dotenv": "^17.4.2",
		"mongoose": "^7.8.10",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"vite": "^7.3.5",
		"vue": "^3.5.34"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@module-federation/runtime-tools": "^2.4.0",
		"@originjs/vite-plugin-federation": "^1.4.1",
		"@rspack/cli": "^2.0.3",
		"@rspack/core": "^2.0.3",
		"@rspack/dev-server": "^2.0.1",
		"@stencil-community/postcss": "^2.2.0",
		"@stencil/core": "^4.43.4",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260514.1",
		"@vitejs/plugin-vue": "^6.0.6",
		"autoprefixer": "^10.5.0",
		"cross-env": "^10.1.0",
		"css-loader": "^7.1.4",
		"eslint": "^10.3.0",
		"knip": "^6.13.1",
		"postcss": "^8.5.14",
		"postcss-loader": "^8.2.1",
		"style-loader": "^4.0.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vue-loader": "^17.4.2"
	},
	"overrides": {
		"baseline-browser-mapping": "^2.9.19",
		"@babel/core": "^7.29.6",
		"esbuild": "^0.28.1",
		"js-yaml": "^4.2.0",
		"postcss": "^8.5.10",
		"qs": "^6.15.2",
		"vite": "^7.3.5",
		"brace-expansion": "^5.0.6",
		"devalue": "^5.8.1",
		"fast-uri": "^3.1.2",
		"flatted": "^3.4.2",
		"ip-address": "^10.2.0",
		"nodemailer": "^9.0.1",
		"path-to-regexp": "0.1.13",
		"rollup": "^4.62.2",
		"serialize-javascript": "^7.0.6"
	},
	"packageManager": "bun"
}
